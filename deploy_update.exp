#!/usr/bin/expect -f

set timeout 60
set password "gyq3160GYQ3160"
set server "47.109.148.176"
set user "root"
set local_file "assistant_web.py"
set remote_path "/var/www/ai-assistant/"

puts "正在上传 assistant_web.py..."
spawn scp $local_file $user@$server:$remote_path
expect {
    "yes/no" {
        send "yes\r"
        exp_continue
    }
    "password:" {
        send "$password\r"
    }
}
expect eof

puts "正在重启服务..."
spawn ssh $user@$server "supervisorctl restart ai-assistant"
expect {
    "yes/no" {
        send "yes\r"
        exp_continue
    }
    "password:" {
        send "$password\r"
    }
}
expect eof

puts "部署完成！"

